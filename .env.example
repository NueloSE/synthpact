# Base Sepolia RPC (Alchemy or Infura)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_key

# Anthropic API key (for Claude agent scripts)
ANTHROPIC_API_KEY=sk-ant-...

# Uniswap Developer Platform API key
UNISWAP_API_KEY=your_uniswap_key

# Deployed contract address (filled after deploy)
SYNTHPACT_CONTRACT_ADDRESS=

# ERC-8004 Registry addresses on Base Sepolia
ERC8004_IDENTITY_REGISTRY=
ERC8004_REPUTATION_REGISTRY=
