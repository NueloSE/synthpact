  },
  "safety_guardrails": [
    "Deal status verified before executing task (prevent wasted compute)",
    "Max price cap on client (no overspending)",
    "Deadline checks before all on-chain writes",
    "Groq output validated as JSON before hashing",
    "Reputation score clamped to ERC-8004 range (-100 to +100)"
  ],
  "integrations": {
