  "agents": [
    {
      "id": "worker-agent-001",
      "role": "worker",
      "erc8004_namespace": "synthpact",
      "erc8004_registry": "0x8004AA63c570c570eBF15376c0dB199918BFe9Fb",
      "model": "llama-3.3-70b-versatile",
      "provider": "groq",
      "capabilities": ["market-analysis", "data-synthesis", "report-generation"],
